{
  "entities": {
    "Member": {
      "title": "Member",
      "description": "Represents a club member or student.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["active", "expired", "pending"] },
        "sessionsCount": { "type": "number" },
        "attendedCount": { "type": "number" },
        "absentCount": { "type": "number" },
        "compensationSessions": { "type": "number" },
        "grade": { "type": "string" },
        "subjects": { "type": "string" },
        "price": { "type": "string" },
        "paidAmount": { "type": "string" },
        "paymentMethod": { "type": "string", "enum": ["كاش", "تحويل", "لم يتم الدفع"] },
        "paymentDate": { "type": "string", "format": "date" },
        "subscriptionDays": { "type": "number" },
        "teacherName": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["id", "name", "startDate", "endDate", "status"]
    },
    "Course": {
      "title": "Course",
      "description": "Represents a training course or workshop.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "instructor": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "capacity": { "type": "number" },
        "enrolledCount": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "upcoming", "completed"] },
        "price": { "type": "string" },
        "duration": { "type": "string" },
        "description": { "type": "string" },
        "cost": { "type": "string" },
        "associationPercentage": { "type": "string" },
        "isSettled": { "type": "boolean" },
        "extraIncome": { "type": "string" },
        "extraExpenses": { "type": "string" }
      },
      "required": ["id", "title", "instructor", "status", "price"]
    },
    "Trainee": {
      "title": "Trainee",
      "description": "Represents a person enrolled in a specific course.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "courseId": { "type": "string" },
        "fullName": { "type": "string" },
        "motherPhone": { "type": "string" },
        "duration": { "type": "string" },
        "amount": { "type": "string" },
        "paymentMethod": { "type": "string", "enum": ["كاش", "تحويل", "لم يتم الدفع"] },
        "date": { "type": "string", "format": "date" },
        "notes": { "type": "string" }
      },
      "required": ["id", "courseId", "fullName", "amount", "paymentMethod", "date"]
    },
    "AttendanceRecord": {
      "title": "AttendanceRecord",
      "description": "Attendance record for a club member.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "memberId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["present", "absent", "absent_compensated", "compensated"] }
      },
      "required": ["id", "memberId", "date", "status"]
    },
    "TeacherAttendance": {
      "title": "TeacherAttendance",
      "description": "Attendance record for a teacher.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "teacherName": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["حاضر", "غائب", "غائب بي تعويض"] }
      },
      "required": ["id", "teacherName", "date", "status"]
    },
    "AppSettings": {
      "title": "AppSettings",
      "description": "Global application configuration.",
      "type": "object",
      "properties": {
        "icons": {
          "type": "object",
          "properties": {
            "activeMember": { "type": "string" },
            "expiredMember": { "type": "string" },
            "present": { "type": "string" },
            "absent": { "type": "string" },
            "compensation": { "type": "string" }
          }
        },
        "financialPassword": { "type": "string" },
        "teachers": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  },
  "firestore": {
    "members": {
      "schema": "Member",
      "description": "Collection of club members."
    },
    "courses": {
      "schema": "Course",
      "description": "Collection of training courses."
    },
    "trainees": {
      "schema": "Trainee",
      "description": "Collection of trainees enrolled in courses."
    },
    "attendance": {
      "schema": "AttendanceRecord",
      "description": "Collection of member attendance records."
    },
    "teacher_attendance": {
      "schema": "TeacherAttendance",
      "description": "Collection of teacher attendance records."
    },
    "settings/global": {
      "schema": "AppSettings",
      "description": "Global settings document."
    }
  }
}
