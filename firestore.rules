rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Primitives
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---

    function isValidMember(data) {
      return data.keys().hasAll(['id', 'name', 'startDate', 'endDate', 'status'])
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 200
        && data.startDate is string && data.startDate.size() <= 32
        && data.endDate is string && data.endDate.size() <= 32
        && data.status in ['active', 'expired', 'pending'];
    }

    function isValidCourse(data) {
      return data.keys().hasAll(['id', 'title', 'instructor', 'status', 'price'])
        && data.id is string && data.id.size() <= 128
        && data.title is string && data.title.size() <= 300
        && data.instructor is string && data.instructor.size() <= 200
        && data.status in ['active', 'upcoming', 'completed']
        && data.price is string && data.price.size() <= 32;
    }

    function isValidTrainee(data) {
      return data.keys().hasAll(['id', 'courseId', 'fullName', 'amount', 'paymentMethod', 'date'])
        && data.id is string && data.id.size() <= 128
        && data.courseId is string && data.courseId.size() <= 128
        && data.fullName is string && data.fullName.size() <= 200
        && data.amount is string && data.amount.size() <= 32
        && data.paymentMethod in ['كاش', 'تحويل', 'لم يتم الدفع']
        && data.date is string && data.date.size() <= 32;
    }

    function isValidAttendance(data) {
      return data.keys().hasAll(['id', 'memberId', 'date', 'status'])
        && data.id is string && data.id.size() <= 128
        && data.memberId is string && data.memberId.size() <= 128
        && data.date is string && data.date.size() <= 32
        && data.status in ['present', 'absent', 'absent_compensated', 'compensated'];
    }

    function isValidTeacherAttendance(data) {
      return data.keys().hasAll(['id', 'teacherName', 'date', 'status'])
        && data.id is string && data.id.size() <= 128
        && data.teacherName is string && data.teacherName.size() <= 200
        && data.date is string && data.date.size() <= 32
        && data.status in ['حاضر', 'غائب', 'غائب بي تعويض'];
    }

    function isValidSettings(data) {
      return data.keys().hasAll(['icons'])
        && data.icons is map
        && (!('financialPassword' in data) || data.financialPassword is string)
        && (!('teachers' in data) || data.teachers is list);
    }

    // --- Collections ---

    match /members/{memberId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(memberId) && isValidMember(incoming());
      allow update: if isSignedIn() && isValidMember(incoming());
      allow delete: if isSignedIn();
    }

    match /courses/{courseId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(courseId) && isValidCourse(incoming());
      allow update: if isSignedIn() && isValidCourse(incoming());
      allow delete: if isSignedIn();
    }

    match /trainees/{traineeId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(traineeId) && isValidTrainee(incoming());
      allow update: if isSignedIn() && isValidTrainee(incoming());
      allow delete: if isSignedIn();
    }

    match /attendance/{recordId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(recordId) && isValidAttendance(incoming());
      allow update: if isSignedIn() && isValidAttendance(incoming());
      allow delete: if isSignedIn();
    }

    match /teacher_attendance/{recordId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(recordId) && isValidTeacherAttendance(incoming());
      allow update: if isSignedIn() && isValidTeacherAttendance(incoming());
      allow delete: if isSignedIn();
    }

    match /settings/global {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidSettings(incoming());
    }
  }
}
